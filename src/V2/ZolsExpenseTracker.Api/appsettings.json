{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "ExpenseDbConnection": "Server=YOUR_SERVER_NAME;Database=ZolsExpenseTrackerV2Db;User Id=YOUR_USERNAME;Password=YOUR_PASSWORD;Trusted_Connection=False;Encrypt=True;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    "Issuer": "ZolsExpenseTracker.Api",
    "Audience": "ZolsExpenseTracker.Client",
    "SecretKey": "YOUR_SUPER_SECRET_MINIMUM_32_CHARACTER_JWT_KEY_HERE"
  },

  "SecurityGates": {
    "SapIntegration": {
      "XApiKeyHeaderName": "X-API-KEY",
      "EnterpriseSecretKey": "YOUR_SAP_API_KEY_HERE"
    },
    "CardIntegration": {
      "WebhookSecret": "YOUR_CARD_WEBHOOK_SECRET_HERE",
      "WebhookUrl": "https://your-card-provider.com/webhooks"
    }
  },

  "AzureResiliency": {
    "ServiceBus": {
      "ConnectionString": "YOUR_AZURE_SERVICE_BUS_CONNECTION_STRING_HERE",
      "CardSwipeQueueName": "zols-expense-card-swipe-queue"
    },
    "KeyVault": {
      "VaultUri": "https://YOUR-KEYVAULT-NAME.vault.azure.net/"
    }
  }
}